# Copiar a `.env` en la raíz del repo (junto a docker-compose.yml)

# --- Obligatorio en producción ---
JWT_SECRET=genera-un-string-largo-y-aleatorio

# Origen del SPA = URL que escribe el usuario en el navegador (CORS del API).
#
# SOLO URL DEL TÚNEL (recomendado en Internet):
#   CLIENT_ORIGIN=https://tu-subdominio.trycloudflare.com
#   (o tu dominio HTTPS; sin barra final; debe coincidir exactamente con la URL del túnel)
#
# Prueba local con Docker (sin túnel):
#   CLIENT_ORIGIN=http://localhost:8080
CLIENT_ORIGIN=https://tu-subdominio.trycloudflare.com

NEW_PEOPLE_DAYS=30

# Cloudflare Zero Trust → Networks → Tunnels → token del conector Docker
# Requerido para: docker compose --profile tunnel up -d
TUNNEL_TOKEN=

# ------------------------------
# QA Platform (qa-system)
# ------------------------------
# URL pública principal para E2E (ejemplo: URL del túnel Cloudflare)
QA_BASE_URL=https://tu-subdominio.trycloudflare.com
QA_EMAIL=demo@fireburst.local
QA_PASSWORD=demo1234
QA_ENV=staging
QA_TAGS=smoke,regression,api
QA_HEADLESS=true
QA_TIMEOUT_MS=25000
QA_RETRIES=1
QA_OUTPUT_DIR=qa-runs

# Ollama local
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
